{
  "name": "ordnungshub",
  "version": "0.1.0",
  "description": "AI-Powered System Organizer App",
  "main": "src/frontend/main.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "start": "electron .",
    "dev": "npm-run-all --parallel dev:backend dev:react dev:electron",
    "dev:backend": "cd src/backend && PYTHONPATH=../.. uvicorn main:app --reload --port 8000",
    "dev:react": "webpack serve --mode development",
    "dev:electron": "wait-on http://localhost:3000 && electron . --dev",
    "build": "webpack --mode production && electron-builder",
    "build:react": "webpack --mode production",
    "test": "jest",
    "test:react": "jest --config jest.react.config.js",
    "lint": "eslint src/frontend --ext .js,.jsx,.ts,.tsx"
  },
  "keywords": [
    "productivity",
    "ai",
    "organizer",
    "desktop-app"
  ],
  "author": "Pascal Hintermaier",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.30",
    "css-loader": "^7.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.28.0",
    "html-webpack-plugin": "^5.6.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.0-beta.3",
    "npm-run-all": "^4.1.5",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.3.4",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
